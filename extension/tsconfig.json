{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"skipLibCheck": true,
		"types": ["chrome", "vitest/globals"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist"]
}
