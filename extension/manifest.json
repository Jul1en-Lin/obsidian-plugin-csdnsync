{
	"manifest_version": 3,
	"name": "CSDN Sync Demo",
	"description": "Open the CSDN editor and fill it with the current Obsidian note.",
	"version": "0.1.3",
	"permissions": ["storage"],
	"host_permissions": [
		"http://127.0.0.1/*",
		"https://editor.csdn.net/*"
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["http://127.0.0.1/*"],
			"js": ["trigger-content.js"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://editor.csdn.net/md*"],
			"js": ["editor-fill-content.js"],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_title": "CSDN Sync",
		"default_popup": "popup.html"
	}
}
